# MyNote Server 配置（pkg 可执行文件）
# 将此文件放在 mynote-server 可执行文件的同级目录
# 不提供此文件则使用默认值

# 监听端口（也可通过命令行 --port 或 -p 指定）
PORT=8081

# 数据目录（存放 mynote.db）
DATA_DIR=./data

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=your-secret-key-change-me-in-production

# JWT 过期天数
JWT_EXPIRE_DAYS=7

# 日志级别 (dev, combined, common, short, tiny)
LOG_LEVEL=dev

# 单文件上传大小限制 (MB)
MAX_UPLOAD_SIZE_MB=10
